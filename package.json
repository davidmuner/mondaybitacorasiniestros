{
  "name": "monday-bitacora-movilidad",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/item-view",
    "server"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=server\" \"npm run dev --workspace=apps/item-view\"",
    "build": "npm run build --workspace=server && npm run build --workspace=apps/item-view",
    "start": "npm run start --workspace=server"
  },
  "dependencies": {
    "@pinojs/redact": "^0.4.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "pino": "^10.3.1",
    "pino-std-serializers": "^7.1.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^22.0.0",
    "@vercel/node": "^5.0.0",
    "concurrently": "^8.2.2",
    "typescript": "^5.5.3"
  }
